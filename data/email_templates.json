{
    "order_admin": {
        "subject": "New order #{order_id} — NicheHome.ch",
        "html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; background: #f5f5f5; margin: 0; padding: 0; }\n        .container { max-width: 700px; margin: 0 auto; padding: 20px; }\n        .header { background: #2c3e50; color: white; padding: 30px; text-align: center; }\n        .header h1 { margin: 0 0 10px 0; font-size: 28px; }\n        .header p { margin: 5px 0; font-size: 18px; }\n        .content { padding: 30px; background: #ffffff; }\n        .info-section { margin: 25px 0; }\n        .info-section h3 { color: #2c3e50; margin: 0 0 15px 0; padding-bottom: 10px; border-bottom: 2px solid #d4af37; font-size: 18px; }\n        .info-box { background: #f9f9f9; padding: 15px; margin: 10px 0; border-left: 4px solid #d4af37; }\n        .info-row { margin: 8px 0; }\n        .info-label { font-weight: bold; color: #555; display: inline-block; width: 150px; }\n        .info-value { color: #333; }\n        .items-table { width: 100%; border-collapse: collapse; margin: 20px 0; }\n        .items-table th { background: #2c3e50; color: white; padding: 12px; text-align: left; font-weight: bold; }\n        .items-table td { padding: 12px; border-bottom: 1px solid #ddd; }\n        .items-table tr:hover { background: #f9f9f9; }\n        .totals-box { background: #f9f9f9; padding: 20px; margin: 20px 0; border: 2px solid #2c3e50; }\n        .totals-row { display: flex; justify-content: space-between; margin: 8px 0; font-size: 16px; }\n        .totals-row.total { font-size: 20px; font-weight: bold; color: #2c3e50; border-top: 2px solid #333; padding-top: 12px; margin-top: 12px; }\n        .footer { text-align: center; padding: 20px; color: #666; font-size: 14px; background: #f5f5f5; }\n        .btn { display: inline-block; background: #d4af37; color: white; padding: 12px 30px; text-decoration: none; border-radius: 4px; margin: 20px 0; font-weight: bold; }\n        .status-badge { display: inline-block; padding: 6px 12px; border-radius: 4px; font-size: 14px; font-weight: bold; }\n        .status-pending { background: #ffc107; color: #000; }\n        .status-paid { background: #28a745; color: #fff; }\n        .status-awaiting { background: #17a2b8; color: #fff; }\n    <\/style>\n<\/head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>🛍️ New Order Received<\/h1>\n            <p>Order #{order_id}<\/p>\n            <p style=\"font-size: 14px; margin-top: 10px;\">{order_date}<\/p>\n        <\/div>\n        \n        <div class=\"content\">\n            <!-- Order Status -->\n            <div class=\"info-section\">\n                <h3>Order Status<\/h3>\n                <div class=\"info-box\">\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Status:<\/span>\n                        <span class=\"info-value\">{order_status_badge}<\/span>\n                    <\/div>\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Order Number:<\/span>\n                        <span class=\"info-value\">{order_id}<\/span>\n                    <\/div>\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Order Date:<\/span>\n                        <span class=\"info-value\">{order_date}<\/span>\n                    <\/div>\n                <\/div>\n            <\/div>\n            \n            <!-- Customer Information -->\n            <div class=\"info-section\">\n                <h3>Customer Information<\/h3>\n                <div class=\"info-box\">\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Name:<\/span>\n                        <span class=\"info-value\">{customer_name}<\/span>\n                    <\/div>\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Email:<\/span>\n                        <span class=\"info-value\"><a href=\"mailto:{customer_email}\">{customer_email}<\/a><\/span>\n                    <\/div>\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Phone:<\/span>\n                        <span class=\"info-value\"><a href=\"tel:{customer_phone}\">{customer_phone}<\/a><\/span>\n                    <\/div>\n                <\/div>\n            <\/div>\n            \n            <!-- Fulfillment Details -->\n            <div class=\"info-section\">\n                <h3>Fulfillment Details<\/h3>\n                {fulfillment_details}\n            <\/div>\n            \n            <!-- Order Items -->\n            <div class=\"info-section\">\n                <h3>Order Items<\/h3>\n                {items_table}\n            <\/div>\n            \n            <!-- Order Totals -->\n            <div class=\"info-section\">\n                <h3>Order Summary<\/h3>\n                <div class=\"totals-box\">\n                    <div class=\"totals-row\">\n                        <span>Subtotal:<\/span>\n                        <span>CHF {subtotal}<\/span>\n                    <\/div>\n                    <div class=\"totals-row\">\n                        <span>Shipping:<\/span>\n                        <span>CHF {shipping}<\/span>\n                    <\/div>\n                    <div class=\"totals-row total\">\n                        <span>Total:<\/span>\n                        <span>CHF {total}<\/span>\n                    <\/div>\n                <\/div>\n            <\/div>\n            \n            <!-- Payment Information -->\n            <div class=\"info-section\">\n                <h3>Payment Information<\/h3>\n                <div class=\"info-box\">\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Payment Method:<\/span>\n                        <span class=\"info-value\">{payment_method}<\/span>\n                    <\/div>\n                    <div class=\"info-row\">\n                        <span class=\"info-label\">Payment Status:<\/span>\n                        <span class=\"info-value\">{payment_status}<\/span>\n                    <\/div>\n                    {transaction_reference}\n                <\/div>\n            <\/div>\n            \n            <!-- Admin Action -->\n            <div style=\"text-align: center; margin-top: 30px;\">\n                <a href=\"https:\/\/nichehome.ch\/admin\/orders.php\" class=\"btn\">View Order in Admin Panel<\/a>\n            <\/div>\n        <\/div>\n        \n        <div class=\"footer\">\n            <p><strong>NicheHome.ch<\/strong> — Admin Order Notification<\/p>\n            <p style=\"margin: 5px 0; font-size: 12px; color: #999;\">This is an automated notification. Do not reply to this email.<\/p>\n        <\/div>\n    <\/div>\n<\/body>\n<\/html>",
        "text": "NEW ORDER RECEIVED\r\n========================================\r\n\r\nOrder Number: #{order_id}\r\nOrder Date: {order_date}\r\nOrder Status: {order_status}\r\n\r\nCUSTOMER INFORMATION\r\n----------------------------------------\r\nName: {customer_name}\r\nEmail: {customer_email}\r\nPhone: {customer_phone}\r\n\r\nFULFILLMENT DETAILS\r\n----------------------------------------\r\n{fulfillment_text}\r\n\r\nORDER ITEMS\r\n----------------------------------------\r\n{items_list}\r\n\r\nORDER SUMMARY\r\n----------------------------------------\r\nSubtotal: CHF {subtotal}\r\nShipping: CHF {shipping}\r\n========================================\r\nTOTAL: CHF {total}\r\n========================================\r\n\r\nPAYMENT INFORMATION\r\n----------------------------------------\r\nPayment Method: {payment_method}\r\nPayment Status: {payment_status}\r\n{transaction_reference_text}\r\n\r\nView order in admin panel:\r\nhttps:\/\/nichehome.ch\/admin\/orders.php\r\n\r\n---\r\nNicheHome.ch Admin Notification\r\nThis is an automated notification."
